<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chrono-Aventure</title>
    <style>
        :root {
            --bg-color: #f0f0f0;
            --main-color: #2c3e50;
            --accent-color: #c0392b;
            --timer-bg: rgba(255, 255, 255, 0.9);
            --interface-bg: #4a6c88;
        }

        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            margin: 0;
            background: linear-gradient(135deg, #eee 25%, transparent 25%) -50px 0,
                        linear-gradient(225deg, #eee 25%, transparent 25%) -50px 0,
                        linear-gradient(315deg, #eee 25%, transparent 25%),
                        linear-gradient(45deg, #eee 25%, transparent 25%);
            background-size: 100px 100px;
            background-color: var(--bg-color);
            color: var(--main-color);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            height: 100vh;
            overflow: hidden;
            touch-action: manipulation;
        }

        #timer-display {
            font-size: 4rem;
            font-weight: 900;
            background-color: var(--timer-bg);
            padding: 20px 40px;
            border-radius: 50px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            margin-top: 5vh;
            margin-bottom: 20px;
            color: var(--accent-color);
            border: 5px solid var(--accent-color);
            font-variant-numeric: tabular-nums;
        }

        .main-interface {
            background-color: #212121;
            width: 80vw;
            height: 80vw;
            max-width: 400px;
            max-height: 400px;
            border-radius: 50%;
            position: relative;
            box-shadow: 0 8px 15px rgba(0,0,0,0.3);
            display: grid;
            grid-template-areas: 
                "hint start start"
                "hidden center code"
                "reviews reviews machine";
            padding: 20px;
            gap: 15px;
            justify-items: center;
            align-items: center;
            color: white;
            text-align: center;
        }

        .penalite-center {
            grid-area: center;
            width: 12vw;
            height: 12vw;
            max-width: 60px;
            max-height: 60px;
            background-color: var(--accent-color);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 0.8rem;
            text-transform: uppercase;
        }

        .icon-btn {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: none;
            border: none;
            cursor: pointer;
            color: white;
            padding: 0;
        }

        .icon-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .icon-graphic {
            width: 8vw;
            height: 8vw;
            max-width: 40px;
            max-height: 40px;
            border-radius: 50%;
            background-color: var(--interface-bg);
            border: 2px solid white;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .icon-graphic span { font-size: 1.5rem; }

        /* Emplacements spécifiques */
        #btn-hint { grid-area: hint; }
        #btn-start { grid-area: start; }
        #btn-code { grid-area: code; }
        #btn-hidden { grid-area: hidden; }
        #btn-reviews { grid-area: reviews; justify-self: start; margin-left: -15px; }
        #btn-machine { grid-area: machine; }

        /* Écran d'entrée de code */
        #code-entry-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background-color: rgba(0,0,0,0.9);
            color: white;
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 100;
        }

        #code-input {
            width: 70%;
            padding: 15px;
            font-size: 2rem;
            border-radius: 10px;
            border: none;
            margin-bottom: 20px;
            text-align: center;
            background: #333;
            color: white;
        }

        /* Classes utilitaires */
        .hidden { display: none; }
        .error-shake { animation: shake 0.5s; }
        @keyframes shake {
            0% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            50% { transform: translateX(10px); }
            100% { transform: translateX(0); }
        }
    </style>
</head>
<body>

    <div id="timer-display">60:00</div>

    <div class="main-interface">
        <div class="penalite-center">Pénalité</div>

        <button class="icon-btn" id="btn-start" onclick="toggleTimer()">
            <span class="icon-label">Start/Pause</span>
            <div class="icon-graphic" id="icon-timer-state"><span>&#x23F5;</span></div> </button>

        <button class="icon-btn" id="btn-hint" onclick="getHint()">
            <span class="icon-label">Indice</span>
            <div class="icon-graphic"><span>&#x1F4A1;</span></div> </button>

        <button class="icon-btn" id="btn-code" onclick="showCodeEntry()">
            <span class="icon-label">Code</span>
            <div class="icon-graphic"><span>&#x1F512;</span></div> </button>

        <button class="icon-btn" id="btn-hidden" onclick="getHiddenObjectHint()">
            <span class="icon-label">Objet Caché</span>
            <div class="icon-graphic"><span>&#x1F50D;</span></div> </button>

        <button class="icon-btn" id="btn-reviews" onclick="reviewIndices()">
            <span class="icon-label">Revoir Indices</span>
            <div class="icon-graphic"><span>&#x1F441;</span></div> </button>

        <button class="icon-btn" id="btn-machine" onclick="showMachineScreen()">
            <span class="icon-label">Machine</span>
            <div class="icon-graphic"><span>&#x2699;</span></div> </button>
    </div>

    <div id="code-entry-screen">
        <h2>Entrez le Code</h2>
        <input type="number" id="code-input" placeholder="4 chiffres" pattern="\d*">
        <div style="display:flex; gap: 10px;">
            <button onclick="checkCode()">Valider</button>
            <button onclick="hideCodeEntry()">Annuler</button>
        </div>
        <p id="code-status"></p>
    </div>

    <script>
        // --- CONFIGURATION PERSONNELLE DE VOTRE SCÉNARIO ---
        const SCENARIO_DATA = {
            codes: {
                "1234": { message: "Vous ouvrez la porte.", carte: "Carte 14" },
                "5555": { message: "Le mécanisme est activé.", carte: "Carte 22" },
                "9999": { message: "FIN DE L'AVENTURE : Félicitations !", finish: true }
            },
            pénalité_minutes: 2
        };

        // --- GESTION DU TIMER ---
        let initialTime = 60 * 60; // 60 minutes par défaut
        let timeLeft = initialTime;
        let timerInterval;
        let isRunning = false;
        const timerDisplay = document.getElementById('timer-display');
        const startIcon = document.getElementById('icon-timer-state').firstElementChild;

        function updateTimerDisplay() {
            if (timeLeft <= 0) {
                timeLeft = 0;
                isRunning = false;
                timerDisplay.innerText = "00:00";
                startIcon.innerHTML = "&#x23F5;"; // Play icon
                clearInterval(timerInterval);
                alert("Temps écoulé ! Votre quête a échoué.");
                return;
            }
            const mins = Math.floor(timeLeft / 60);
            const secs = timeLeft % 60;
            timerDisplay.innerText = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
        }

        function toggleTimer() {
            if (!isRunning) {
                if (timeLeft === 0) timeLeft = initialTime; // Recommencer
                isRunning = true;
                timerInterval = setInterval(() => {
                    timeLeft--;
                    updateTimerDisplay();
                }, 1000);
                startIcon.innerHTML = "&#x23F8;"; // Pause icon
            } else {
                isRunning = false;
                clearInterval(timerInterval);
                startIcon.innerHTML = "&#x23F5;"; // Play icon
            }
        }

        // --- GESTION DES CODES ET PÉNALITÉS ---
        const codeEntryScreen = document.getElementById('code-entry-screen');
        const codeInput = document.getElementById('code-input');
        const codeStatus = document.getElementById('code-status');

        function showCodeEntry() {
            if (!isRunning) return alert("Le timer doit être démarré pour utiliser l'interface.");
            codeEntryScreen.style.display = 'flex';
            codeInput.focus();
        }

        function hideCodeEntry() {
            codeEntryScreen.style.display = 'none';
            codeInput.value = '';
            codeStatus.innerHTML = '';
        }

        // Préchargement des sons (assurez-vous que bip.mp3 et bravo.mp3 existent)
        const soundPenalty = new Audio('bip.mp3'); 
        const soundSuccess = new Audio('bravo.mp3');

        function checkCode() {
            const userCode = codeInput.value;
            const result = SCENARIO_DATA.codes[userCode];

            if (result) {
                soundSuccess.play().catch(e=>console.log("Audio bloqué par le navigateur", e));
                alert(`${result.message}\n${result.carte ? `Prenez la carte : ${result.carte}` : ''}`);
                if (result.finish) {
                    toggleTimer(); // Arrêter le chrono
                }
                hideCodeEntry();
            } else {
                // Pénalité
                soundPenalty.play().catch(e=>console.log("Audio bloqué par le navigateur", e));
                codeStatus.innerHTML = `<span style="color:red">Mauvais code ! Pénalité de -${SCENARIO_DATA.pénalité_minutes}min.</span>`;
                codeInput.parentElement.classList.add('error-shake');
                setTimeout(() => codeInput.parentElement.classList.remove('error-shake'), 500);
                
                timeLeft -= (SCENARIO_DATA.pénalité_minutes * 60);
                updateTimerDisplay();
                codeInput.value = ''; // Effacer le mauvais code
            }
        }

        // --- AUTRES BOUTONS D'INTERFACE (Stubs pour le moment) ---
        function getHint() { alert("FONCTION INDICE : J'afficherai un indice ici."); }
        function getHiddenObjectHint() { alert("FONCTION OBJET CACHÉ : J'afficherai un indice ici."); }
        function reviewIndices() { alert("FONCTION REVOIR INDICES : J'afficherai une liste des indices trouvés."); }
        function showMachineScreen() { alert("FONCTION MACHINE : J'afficherai une interface spécifique ici."); }

        // Initialiser l'affichage
        updateTimerDisplay();
    </script>
</body>
</html>
